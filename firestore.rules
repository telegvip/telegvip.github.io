rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.uid == 'nMOQ6jgrGWQGK6NFBroiZIT8gKH2';
    }

    function validBuyerFields(data) {
      return data.buyerName is string
        && data.buyerName.size() >= 2
        && data.buyerName.size() <= 120
        && data.buyerEmail is string
        && data.buyerEmail.size() >= 5
        && data.buyerEmail.size() <= 254
        && data.buyerWhatsApp is string
        && data.buyerWhatsApp.size() <= 40
        && data.buyerTelegram is string
        && data.buyerTelegram.size() <= 80;
    }

    function validOrderBase(data) {
      return signedIn()
        && data.ownerUid == request.auth.uid
        && data.accessLink == ''
        && data.adminNote == ''
        && data.currency == 'USD'
        && data.durationDays == 30
        && validBuyerFields(data)
        && data.profileId is string
        && data.profileTitle is string
        && data.price is number
        && data.price >= 0
        && data.price <= 10000
        && data.orderNumber is int
        && data.orderNumber >= 8300
        && data.orderCode is string
        && data.orderCode.matches('VIP-[0-9]+')
        && data.source == 'web';
    }

    function validNewOrder() {
      let data = request.resource.data;
      return validOrderBase(data)
        && data.status in ['awaiting_payment', 'pending']
        && data.paymentMethod in ['Pendiente', 'Tarjeta', 'USDT', 'USDC', 'Binance Pay']
        && data.paymentAsset is string
        && data.paymentNetwork is string
        && data.paymentAddress is string
        && data.proofUrl is string
        && data.proofPath is string
        && (
          (data.status == 'awaiting_payment'
            && data.paymentMethod == 'Pendiente'
            && data.proofUrl == ''
            && data.proofPath == '')
          ||
          (data.status == 'pending'
            && data.paymentMethod in ['Tarjeta', 'USDT', 'USDC', 'Binance Pay']
            && data.proofUrl.size() > 0
            && data.proofPath.matches('telegram-vip/proofs/' + request.auth.uid + '/.*'))
        )
        && getAfter(/databases/$(database)/documents/telegramVip_counters/orders).data.lastNumber == data.orderNumber
        && getAfter(/databases/$(database)/documents/telegramVip_counters/orders).data.lastOrderUid == request.auth.uid;
    }

    function validPendingBuyerUpdate() {
      return signedIn()
        && resource.data.ownerUid == request.auth.uid
        && resource.data.status == 'awaiting_payment'
        && request.resource.data.status == 'awaiting_payment'
        && validBuyerFields(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'buyerName',
          'buyerEmail',
          'buyerWhatsApp',
          'buyerTelegram',
          'updatedAt'
        ]);
    }

    function validProofSubmission() {
      return signedIn()
        && resource.data.ownerUid == request.auth.uid
        && resource.data.status == 'awaiting_payment'
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentMethod in ['Tarjeta', 'USDT', 'USDC', 'Binance Pay']
        && request.resource.data.paymentAsset is string
        && request.resource.data.paymentNetwork is string
        && request.resource.data.paymentAddress is string
        && request.resource.data.proofUrl is string
        && request.resource.data.proofUrl.size() > 0
        && request.resource.data.proofPath is string
        && request.resource.data.proofPath.matches('telegram-vip/proofs/' + request.auth.uid + '/.*')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'paymentMethod',
          'paymentAsset',
          'paymentNetwork',
          'paymentAddress',
          'proofUrl',
          'proofPath',
          'status',
          'updatedAt'
        ]);
    }

    match /telegramVip_site/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /telegramVip_profiles/{profileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /telegramVip_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /telegramVip_testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /telegramVip_activity/{activityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /telegramVip_counters/{counterId} {
      allow read: if true;
      allow create: if isAdmin()
        || (signedIn()
          && (
            (counterId == 'profileSessions'
              && request.resource.data.keys().hasOnly(['lastNumber', 'lastSessionUid', 'updatedAt'])
              && request.resource.data.lastNumber == 4208
              && request.resource.data.lastSessionUid == request.auth.uid)
            ||
            (counterId == 'orders'
              && request.resource.data.keys().hasOnly(['lastNumber', 'lastOrderUid', 'updatedAt'])
              && request.resource.data.lastNumber == 8300
              && request.resource.data.lastOrderUid == request.auth.uid)
          ));
      allow update: if isAdmin()
        || (signedIn()
          && (
            (counterId == 'profileSessions'
              && request.resource.data.keys().hasOnly(['lastNumber', 'lastSessionUid', 'updatedAt'])
              && request.resource.data.lastNumber == resource.data.lastNumber + 1
              && request.resource.data.lastSessionUid == request.auth.uid)
            ||
            (counterId == 'orders'
              && request.resource.data.keys().hasOnly(['lastNumber', 'lastOrderUid', 'updatedAt'])
              && request.resource.data.lastNumber == resource.data.lastNumber + 1
              && request.resource.data.lastOrderUid == request.auth.uid)
          ));
      allow delete: if isAdmin();
    }

    match /telegramVip_orders/{orderId} {
      allow create: if validNewOrder();
      allow read: if isAdmin()
        || (signedIn() && resource.data.ownerUid == request.auth.uid);
      allow update: if isAdmin()
        || validPendingBuyerUpdate()
        || validProofSubmission();
      allow delete: if isAdmin();
    }

    match /telegramVip_reactions/{profileId}/posts/{postId}/telegramVip_post_reactions/{userId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['emoji', 'updatedAt'])
        && request.resource.data.emoji in ['❤️','🔥','😍','🥵','😈','💋'];
      allow delete: if signedIn() && request.auth.uid == userId;
    }



    // V41 · Estadísticas anónimas de TELEGVIP
    function validAnalyticsEvent(data) {
      return signedIn()
        && data.ownerUid == request.auth.uid
        && data.keys().hasOnly([
          'ownerUid',
          'sessionId',
          'eventType',
          'page',
          'profileId',
          'profileTitle',
          'device',
          'referrerHost',
          'isReturning',
          'value',
          'createdAt'
        ])
        && data.sessionId is string
        && data.sessionId.size() >= 6
        && data.sessionId.size() <= 140
        && data.eventType in [
          'session_start',
          'page_view',
          'profile_view',
          'checkout_open',
          'checkout_continue',
          'payment_select',
          'proof_submitted'
        ]
        && data.page is string
        && data.page.size() <= 180
        && data.profileId is string
        && data.profileId.size() <= 100
        && data.profileTitle is string
        && data.profileTitle.size() <= 120
        && data.device in ['mobile', 'tablet', 'desktop']
        && data.referrerHost is string
        && data.referrerHost.size() <= 120
        && data.isReturning is bool
        && data.value is string
        && data.value.size() <= 80
        && data.createdAt == request.time;
    }

    function validAnalyticsPresence(data, visitorId) {
      return signedIn()
        && visitorId == request.auth.uid
        && data.ownerUid == request.auth.uid
        && data.keys().hasOnly([
          'ownerUid',
          'sessionId',
          'page',
          'profileId',
          'profileTitle',
          'device',
          'lastSeen'
        ])
        && data.sessionId is string
        && data.sessionId.size() >= 6
        && data.sessionId.size() <= 140
        && data.page is string
        && data.page.size() <= 180
        && data.profileId is string
        && data.profileId.size() <= 100
        && data.profileTitle is string
        && data.profileTitle.size() <= 120
        && data.device in ['mobile', 'tablet', 'desktop']
        && data.lastSeen == request.time;
    }

    match /telegramVip_analytics_events/{eventId} {
      allow create: if isAdmin() || validAnalyticsEvent(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /telegramVip_analytics_presence/{visitorId} {
      allow create, update: if isAdmin()
        || validAnalyticsPresence(request.resource.data, visitorId);
      allow read, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
