rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.uid == 'nMOQ6jgrGWQGK6NFBroiZIT8gKH2';
    }

    function validMedia(maxBytes) {
      return request.resource != null
        && request.resource.size < maxBytes
        && request.resource.contentType.matches('(image|video|audio)/.*');
    }

    function validImage(maxBytes) {
      return request.resource != null
        && request.resource.size < maxBytes
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /telegram-vip/profiles/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && validMedia(100 * 1024 * 1024);
      allow delete: if isAdmin();
    }

    match /telegram-vip/testimonials/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && validImage(10 * 1024 * 1024);
      allow delete: if isAdmin();
    }

    match /telegram-vip/settings/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && validImage(10 * 1024 * 1024);
      allow delete: if isAdmin();
    }

    match /telegram-vip/proofs/{userId}/{orderId}/{fileName} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && validImage(10 * 1024 * 1024);
      allow read: if isAdmin()
        || (signedIn() && request.auth.uid == userId);
      allow update, delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
