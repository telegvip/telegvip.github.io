rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.uid == 'nMOQ6jgrGWQGK6NFBroiZIT8gKH2';
    }

    function validAdminMedia() {
      return request.resource != null
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('(image|video)/.*');
    }

    function validProof() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /telegram-vip/profiles/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && validAdminMedia();
      allow delete: if isAdmin();
    }

    match /telegram-vip/testimonials/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && validAdminMedia();
      allow delete: if isAdmin();
    }

    match /telegram-vip/proofs/{userId}/{orderId}/{fileName} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && validProof();
      allow read: if isAdmin()
        || (signedIn() && request.auth.uid == userId);
      allow update, delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
